      ]
    ]
  },
  {
    "id": "c3_fn_select_classify",
    "type": "function",
    "z": "c3_tab_main",
    "name": "select Packet Number N + classify",
    "func": "let row = null;\n\nif (Array.isArray(msg.payload)) {\n    row = msg.payload.find(r => Number(r['Packet Number']) === Number(msg.N));\n} else if (msg.payload && typeof msg.payload === 'object') {\n    if (Number(msg.payload['Packet Number']) !== Number(msg.N)) {\n        return null;\n    }\n    row = msg.payload;\n} else {\n    node.error('Unexpected CSV payload format', msg);\n    return null;\n}\n\nif (!row) {\n    node.warn(`No CSV row found for Packet Number ${msg.N}`);\n    return null;\n}\n\nmsg.csvRow = row;\nmsg.commandString = row['Command String'] || '';\n\nconst isZcl = msg.commandString.includes('ZBEE_ZCL');\nconst isLinkStatus = row['Packet Type'] === 'Link Status (0x08)';\n\nlet doneMsg = null;\nif (flow.get('challenge_done') && !flow.get('thingspeak_started')) {\n    flow.set('thingspeak_started', true);\n    doneMsg = { payload: '200 ID messages processed' };\n}\n\nif (isZcl) {\n    return [msg, null, doneMsg, null];\n}\nif (isLinkStatus) {\n    return [null, msg, doneMsg, null];\n}\nreturn [null, null, doneMsg, msg];",
    "outputs": 4,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1080,
    "y": 430,
    "wires": [
      [
