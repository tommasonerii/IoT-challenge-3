  {
    "id": "c3_fn_count_id",
    "type": "function",
    "z": "c3_tab_main",
    "name": "count <=200 + N=id%5218",
    "func": "if (flow.get('challenge_done')) {\n    return null;\n}\n\nlet payload = msg.payload;\nif (typeof payload === 'string') {\n    payload = JSON.parse(payload);\n}\n\nconst id = Number(payload.id);\nif (!Number.isFinite(id)) {\n    node.error('Invalid ID payload', msg);\n    return null;\n}\n\nconst count = (flow.get('id_rx_count') || 0) + 1;\nflow.set('id_rx_count', count);\n\nmsg.sub_id = id;\nmsg.sub_timestamp = payload.timestamp;\nmsg.id_rx_count = count;\nmsg.N = id % 5218;\n\nif (count >= 200) {\n    flow.set('challenge_done', true);\n}\n\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 340,
    "y": 430,
    "wires": [
      [
        "c3_filein_csv"
      ]
    ]
  },
