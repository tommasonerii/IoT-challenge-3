  {
    "id": "c3_fn_prepare_zcl",
    "type": "function",
    "z": "c3_tab_main",
    "name": "prepare ZBEE_ZCL MQTT payload",
    "func": "const row = msg.csvRow;\nconst dev = row['Device Name ZigBee Source'];\nconst topic = `ZigBee/${dev}`;\nconst currentTimestamp = Math.floor(Date.now() / 1000);\n\nmsg.topic = topic;\nmsg.currentTimestamp = currentTimestamp;\nmsg.payload = JSON.stringify({\n    timestamp: currentTimestamp,\n    id: msg.sub_id,\n    'wpan.src': row['Source Address'],\n    'wpan.dst': row['Destination Address'],\n    'zbee.src': row['Source Address ZigBee'],\n    'zbee.dst': row['Destination Address ZigBee'],\n    topic: topic,\n    payload: row['Command String']\n});\n\nreturn msg;",
    "outputs": 1,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 260,
    "y": 650,
