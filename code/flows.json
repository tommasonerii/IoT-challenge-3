  {
    "id": "c3_fn_generate_id",
    "type": "function",
    "z": "c3_tab_main",
    "name": "generate MQTT ID + CSV row",
    "func": "if (flow.get('challenge_done')) {\n    return null;\n}\n\nconst id = Math.floor(Math.random() * 30001);\nconst timestamp = Math.floor(Date.now() / 1000);\nconst no = (flow.get('id_log_no') || 0) + 1;\nflow.set('id_log_no', no);\n\nconst mqttMsg = {\n    topic: 'challenge3/id_generator',\n    payload: JSON.stringify({ id, timestamp })\n};\n\nconst csvMsg = {\n    payload: `${no},${id},${timestamp}\\n`\n};\n\nreturn [mqttMsg, csvMsg];",
    "outputs": 2,
    "timeout": 0,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 390,
    "y": 280,
    "wires": [
      [
        "c3_mqtt_id_out"
      ],
      [
        "c3_file_idlog_append"
      ]
    ]
  },
