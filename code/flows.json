    "id": "c3_csv_parse",
    "type": "csv",
    "z": "c3_tab_main",
    "name": "parse CSV to array",
    "sep": ",",
    "hdrin": true,
    "hdrout": "none",
    "multi": "one",
    "ret": "\\n",
    "temp": "",
    "skip": "0",
    "strings": true,
    "include_empty_strings": "",
    "include_null_values": "",
    "x": 810,
